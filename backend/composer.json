{
    "name": "dungeon-core/backend",
    "description": "Dungeon Core Game Backend API",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "firebase/php-jwt": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "autoload": {
        "psr-4": {
            "DungeonCore\\": "src/"
        }
    },
    "scripts": {
        "start": "php -S localhost:8000 -t public",
        "test": "phpunit",
        "cs-check": "phpcs --standard=PSR12 src public config",
        "cs-fix": "phpcbf --standard=PSR12 src public config"
    },
    "config": {
        "optimize-autoloader": true
    }
}
